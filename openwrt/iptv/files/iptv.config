config service 'main'
	option enabled '0'
	option user ''
	option passwd ''
	option mac ''
	option imei ''
	option bind '[::]:7088'
	option address ''
	option interface 'pppoe-iptv'
	option udp_proxy '1'
	option rtsp_proxy '1'
	option manage_enabled '1'
	option auth_token ''
	list auth_protect 'playlist'
	list auth_protect 'xmltv'
	list auth_protect 'manage'
	list auth_protect 'rtsp'
	list auth_protect 'udp'
	list auth_protect 'logo'
	option fcc_enabled '0'
	option fcc_max_redirects '5'
	option fcc_switch_extra_packets '64'
	option fcc_switch_min_unicast_ms '500'
	option alias_mode 'first_match'
	option default_group '未分组'
	option xmltv_use_alias_name '1'
	list same_alias 'resolution_desc'
	list same_alias 'prefer_resolution'
	list same_alias 'original'
	list source_priority 'gd-iptv'
	list source_priority 'extra:0'
	list prefer_resolution 'R4K'
	list prefer_resolution 'Uhd'
	list prefer_resolution 'Fhd'
	list prefer_resolution 'Hd'
	list prefer_resolution 'Sd'
	list prefer_resolution 'Unknown'

config alias_rule
	option type 'regex'
	option pattern '(?i)^CCTV\s*[-\s]*\s*4K.*$'
	option replace 'CCTV4K'

config alias_rule
	option type 'regex'
	option pattern '(?i)^CCTV\s*[-\s]*\s*4.*$'
	option replace 'CCTV4'

config alias_rule
	option type 'regex'
	option pattern '(?i)^CCTV\s*[-\s]*\s*5(?:\s*(?:[+＋]|P(?:LUS)?)).*$'
	option replace 'CCTV5+'

config alias_rule
	option type 'regex'
	option pattern '(?i)^CCTV[-\s]*(\d{1,2}(?:\s*K)?).*'
	option replace 'CCTV$1'

config alias_rule
	option type 'regex'
	option pattern '^广东\s*4K.*$'
	option replace '广东4K'

config alias_rule
	option type 'regex'
	option pattern '^CGTN.*$'
	option replace 'CGTN'

config alias_rule
	option type 'regex'
	option pattern '^广东卫视\s*4k.*$'
	option replace '广东卫视'

config alias_rule
	option type 'regex'
	option pattern '(?i)^(.+?)(?:[-\s]|高清|超清|超高清|4K|[25]0P|时移|专用|测试)*$'
	option replace '$1'

config resolution_rule
	option pattern '(?i)4k|2160p|ultra\s*hd|uhd'
	option score '400'
	option label 'R4K'

config resolution_rule
	option pattern '(?i)超高清'
	option score '350'
	option label 'Uhd'

config resolution_rule
	option pattern '(?i)超清|1080p|fhd'
	option score '300'
	option label 'Fhd'

config resolution_rule
	option pattern '(?i)高清|720p|hd'
	option score '200'
	option label 'Hd'

config resolution_rule
	option pattern '(?i)标清|sd|576p|480p'
	option score '100'
	option label 'Sd'

